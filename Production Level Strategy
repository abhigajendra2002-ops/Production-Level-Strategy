        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "def calculate_level_strategy():\n",
        "    print(\"Level Strategy: Maintain constant production each month. Use inventory/backorders to absorb demand fluctuations.\")\n",
        "    print(f\"{'Total Demand:':<15} {10000}\\n\")\n",
        "\n",
        "    HOLDING_COST_RATE = 5\n",
        "    BACKORDER_COST_RATE = 8\n",
        "    REGULAR_COST = 4800\n",
        "    WORKERS = 8\n",
        "    PRODUCTION = 1600\n",
        "\n",
        "    months = [\"January\", \"February\", \"March\", \"April\", \"May\", \"June\"]\n",
        "    demands = [1000, 1200, 1400, 2000, 2400, 2000]\n",
        "\n",
        "    beg_inventory = 0\n",
        "    total_demand = total_workers = total_production = total_beg_inv = total_end_inv = total_backorders = total_units_held = total_holding_cost = total_backorder_cost = total_regular_cost = 0\n",
        "\n",
        "    reg_costs, hold_costs, back_costs = [], [], []\n",
        "\n",
        "    headers = [\"Month\", \"Demand\", \"Workers\", \"Production\", \"Beg. Inventory\", \"Ending Inventory\", \"Backorders\", \"Units Held\", \"Holding Cost\", \"Backorder Cost\", \"Regular Cost\"]\n",
        "    header_format = \"{:<10} | {:>8} | {:>7} | {:>10} | {:>14} | {:>16} | {:>10} | {:>10} | {:>12} | {:>14} | {:>12}\"\n",
        "    print(\"-\" * 145)\n",
        "    print(header_format.format(*headers))\n",
        "    print(\"-\" * 145)\n",
        "\n",
        "    for i in range(len(months)):\n",
        "        month = months[i]\n",
        "        demand = demands[i]\n",
        "\n",
        "        net_inventory = beg_inventory + PRODUCTION - demand\n",
        "\n",
        "        if net_inventory >= 0:\n",
        "            ending_inventory = net_inventory\n",
        "            backorders = 0\n",
        "        else:\n",
        "            ending_inventory = 0\n",
        "            backorders = abs(net_inventory)\n",
        "\n",
        "        units_held = ending_inventory\n",
        "        holding_cost = units_held * HOLDING_COST_RATE\n",
        "        backorder_cost = backorders * BACKORDER_COST_RATE\n",
        "\n",
        "        reg_costs.append(REGULAR_COST)\n",
        "        hold_costs.append(holding_cost)\n",
        "        back_costs.append(backorder_cost)\n",
        "\n",
        "        row_data = [month, demand, WORKERS, PRODUCTION, beg_inventory, ending_inventory, backorders, units_held, f\"${holding_cost:,.0f}\", f\"${backorder_cost:,.0f}\", f\"${REGULAR_COST:,.0f}\"]\n",
        "        print(header_format.format(*row_data))\n",
        "\n",
        "        total_demand += demand\n",
        "        total_workers += WORKERS\n",
        "        total_production += PRODUCTION\n",
        "        total_beg_inv += beg_inventory\n",
        "        total_end_inv += ending_inventory\n",
        "        total_backorders += backorders\n",
        "        total_units_held += units_held\n",
        "        total_holding_cost += holding_cost\n",
        "        total_backorder_cost += backorder_cost\n",
        "        total_regular_cost += REGULAR_COST\n",
        "        beg_inventory = ending_inventory\n",
        "\n",
        "    print(\"-\" * 145)\n",
        "    totals_row = [\"TOTAL\", total_demand, total_workers, total_production, total_beg_inv, total_end_inv, total_backorders, total_units_held, f\"${total_holding_cost:,.0f}\", f\"${total_backorder_cost:,.0f}\", f\"${total_regular_cost:,.0f}\"]\n",
        "    print(header_format.format(*totals_row))\n",
        "    print(\"-\" * 145)\n",
        "\n",
        "    total_strategy_cost = total_holding_cost + total_backorder_cost + total_regular_cost\n",
        "\n",
        "    print(\"\\n\")\n",
        "    print(f\"{'Hiring Cost:':<25} $0 (no workforce change)\")\n",
        "    print(f\"{'Layoff Cost:':<25} $0 (no workforce change)\")\n",
        "    print(\"-\" * 50)\n",
        "    print(f\"{'TOTAL LEVEL STRATEGY COST':<25} ${total_strategy_cost:,.0f}\")\n",
        "\n",
        "    return total_strategy_cost, {\"Regular Cost\": reg_costs, \"Holding Cost\": hold_costs, \"Backorder Cost\": back_costs}\n",
        "\n",
        "def calculate_chase_strategy():\n",
        "    print(\"CHASE STRATEGY — Match Production to Demand Each Month\")\n",
        "    print(\"Chase Strategy: Hire/lay off workers each month so production exactly matches demand. Zero inventory, zero backorders.\\n\")\n",
        "\n",
        "    UNITS_PER_WORKER = 200\n",
        "    HIRING_COST_RATE = 2400\n",
        "    LAYOFF_COST_RATE = 3000\n",
        "    REGULAR_COST_RATE = 600\n",
        "\n",
        "    months = [\"January\", \"February\", \"March\", \"April\", \"May\", \"June\"]\n",
        "    demands = [1000, 1200, 1400, 2000, 2400, 2000]\n",
        "\n",
        "    workers_available = 8\n",
        "    total_demand = total_workers_needed = total_workers_avail = total_hired = total_laid_off = total_production = total_hiring_cost = total_layoff_cost = total_regular_cost = 0\n",
        "\n",
        "    reg_costs, hire_costs, layoff_costs = [], [], []\n",
        "\n",
        "    headers = [\"Month\", \"Demand\", \"Workers Needed\", \"Workers Availab\", \"Workers Hired\", \"Workers Laid Off\", \"Production\", \"Hiring Cost\", \"Layoff Cost\", \"Regular Cost\", \"Inventory\", \"Backorders\"]\n",
        "    header_format = \"{:<10} | {:>8} | {:>14} | {:>15} | {:>13} | {:>16} | {:>10} | {:>11} | {:>11} | {:>12} | {:>9} | {:>10}\"\n",
        "    print(\"-\" * 155)\n",
        "    print(header_format.format(*headers))\n",
        "    print(\"-\" * 155)\n",
        "\n",
        "    for i in range(len(months)):\n",
        "        month = months[i]\n",
        "        demand = demands[i]\n",
        "\n",
        "        workers_needed = int(demand / UNITS_PER_WORKER)\n",
        "        production = demand\n",
        "\n",
        "        if workers_needed > workers_available:\n",
        "            workers_hired = workers_needed - workers_available\n",
        "            workers_laid_off = 0\n",
        "        elif workers_needed < workers_available:\n",
        "            workers_hired = 0\n",
        "            workers_laid_off = workers_available - workers_needed\n",
        "        else:\n",
        "            workers_hired = 0\n",
        "            workers_laid_off = 0\n",
        "\n",
        "        hiring_cost = workers_hired * HIRING_COST_RATE\n",
        "        layoff_cost = workers_laid_off * LAYOFF_COST_RATE\n",
        "        regular_cost = workers_needed * REGULAR_COST_RATE\n",
        "\n",
        "        reg_costs.append(regular_cost)\n",
        "        hire_costs.append(hiring_cost)\n",
        "        layoff_costs.append(layoff_cost)\n",
        "\n",
        "        row_data = [month, demand, workers_needed, workers_available, workers_hired, workers_laid_off, production, f\"${hiring_cost:,.0f}\", f\"${layoff_cost:,.0f}\", f\"${regular_cost:,.0f}\", 0, 0]\n",
        "        print(header_format.format(*row_data))\n",
        "\n",
        "        total_demand += demand\n",
        "        total_workers_needed += workers_needed\n",
        "        total_workers_avail += workers_available\n",
        "        total_hired += workers_hired\n",
        "        total_laid_off += workers_laid_off\n",
        "        total_production += production\n",
        "        total_hiring_cost += hiring_cost\n",
        "        total_layoff_cost += layoff_cost\n",
        "        total_regular_cost += regular_cost\n",
        "        workers_available = workers_needed\n",
        "\n",
        "    print(\"-\" * 155)\n",
        "    totals_row = [\"TOTAL\", total_demand, total_workers_needed, total_workers_avail, total_hired, total_laid_off, total_production, f\"${total_hiring_cost:,.0f}\", f\"${total_layoff_cost:,.0f}\", f\"${total_regular_cost:,.0f}\", \"$0\", \"$0\"]\n",
        "    print(header_format.format(*totals_row))\n",
        "    print(\"-\" * 155)\n",
        "\n",
        "    total_strategy_cost = total_hiring_cost + total_layoff_cost + total_regular_cost\n",
        "\n",
        "    print(\"\\n\")\n",
        "    print(f\"{'Holding Cost:':<25} $0 (no inventory carried)\")\n",
        "    print(f\"{'Backorder Cost:':<25} $0 (production matches demand)\")\n",
        "    print(\"-\" * 50)\n",
        "    print(f\"{'TOTAL CHASE STRATEGY COST':<25} ${total_strategy_cost:,.0f}\")\n",
        "\n",
        "    return total_strategy_cost, {\"Regular Cost\": reg_costs, \"Hiring Cost\": hire_costs, \"Layoff Cost\": layoff_costs}\n",
        "\n",
        "def calculate_mixed_strategy():\n",
        "    print(\"MIXED STRATEGY — 5 Workers: Regular Time + Overtime (25%) + Subcontracting\")\n",
        "    print(\"Strategy: Reduce from 8 -> 5 workers (lay off 3 @ $3,000 each = $9,000 one-time cost). Regular: 5x200=1,000 units/month. Max OT: 5x50=250 units/month. Subcontract any remaining shortfall. No inventory carry (regular <= demand in all months).\\n\")\n",
        "\n",
        "    print(\" \" * 65 + \"KEY PARAMETERS\")\n",
        "    p_headers = [\"Workers\", \"Reg. Cap/Worker\", \"Regular Prod/Month\", \"Max OT/Worker\", \"Max OT/Month\", \"Reg Cost ($/unit)\", \"OT Cost ($/unit)\", \"SC Cost ($/unit)\", \"Hold Cost ($/unit/mo)\"]\n",
        "    p_vals = [\"5\", \"200\", \"1000\", \"50\", \"250\", \"3\", \"4.5\", \"6\", \"5\"]\n",
        "    p_format = \"{:<7} | {:<15} | {:<18} | {:<13} | {:<12} | {:<17} | {:<15} | {:<15} | {:<20}\"\n",
        "    print(\"-\" * 155)\n",
        "    print(p_format.format(*p_headers))\n",
        "    print(p_format.format(*p_vals))\n",
        "    print(\"-\" * 155)\n",
        "\n",
        "    print(\"\\nONE-TIME LAYOFF COST: 8 - 5 = 3 workers laid off x $3,000 = $9,000 | This cost is added once to the grand total below.\\n\")\n",
        "\n",
        "    demands = [1000, 1200, 1400, 2000, 2400, 2000]\n",
        "    months = [\"January\", \"February\", \"March\", \"April\", \"May\", \"June\"]\n",
        "\n",
        "    REG_PROD = 1000\n",
        "    MAX_OT = 250\n",
        "\n",
        "    total_demand = total_reg_prod = total_max_ot = total_ot_used = total_sc = total_supply = total_end_inv = total_reg_cost = total_ot_cost = total_sc_cost = total_hold_cost = total_monthly = 0\n",
        "\n",
        "    reg_costs, ot_costs, sc_costs = [], [], []\n",
        "\n",
        "    headers = [\"Month\", \"Demand\", \"Reg. Prod\", \"Max OT\", \"OT Used\", \"Subcontracted\", \"Total Supply\", \"End Inventory\", \"Reg. Cost\", \"OT Cost\", \"SC Cost\", \"Hold Cost\", \"Monthly Total\"]\n",
        "    h_format = \"{:<20} | {:>8} | {:>9} | {:>8} | {:>9} | {:>13} | {:>12} | {:>13} | {:>10} | {:>9} | {:>9} | {:>9} | {:>13}\"\n",
        "    print(\"-\" * 172)\n",
        "    print(h_format.format(*headers))\n",
        "    print(\"-\" * 172)\n",
        "\n",
        "    for i in range(len(months)):\n",
        "        month = months[i]\n",
        "        demand = demands[i]\n",
        "\n",
        "        reg_prod = REG_PROD\n",
        "        max_ot = MAX_OT\n",
        "\n",
        "        shortfall = max(0, demand - reg_prod)\n",
        "        ot_used = min(shortfall, max_ot)\n",
        "        subcontracted = max(0, shortfall - ot_used)\n",
        "\n",
        "        total_sup = reg_prod + ot_used + subcontracted\n",
        "        end_inv = 0\n",
        "\n",
        "        reg_cost = 4500\n",
        "        ot_cost = ot_used * 6\n",
        "        sc_cost = subcontracted * 5\n",
        "        hold_cost = 0\n",
        "        monthly_total = reg_cost + ot_cost + sc_cost + hold_cost\n",
        "\n",
        "        reg_costs.append(reg_cost)\n",
        "        ot_costs.append(ot_cost)\n",
        "        sc_costs.append(sc_cost)\n",
        "\n",
        "        row = [month, demand, reg_prod, max_ot, ot_used, subcontracted, total_sup, end_inv, f\"${reg_cost:,.0f}\", f\"${ot_cost:,.0f}\", f\"${sc_cost:,.0f}\", f\"${hold_cost:,.0f}\", f\"${monthly_total:,.0f}\"]\n",
        "        print(h_format.format(*row))\n",
        "\n",
        "        total_demand += demand\n",
        "        total_reg_prod += reg_prod\n",
        "        total_max_ot += max_ot\n",
        "        total_ot_used += ot_used\n",
        "        total_sc += subcontracted\n",
        "        total_supply += total_sup\n",
        "        total_reg_cost += reg_cost\n",
        "        total_ot_cost += ot_cost\n",
        "        total_sc_cost += sc_cost\n",
        "        total_monthly += monthly_total\n",
        "\n",
        "    print(\"-\" * 172)\n",
        "    totals = [\"TOTAL (excl. Layoff)\", total_demand, total_reg_prod, total_max_ot, total_ot_used, total_sc, total_supply, 0, f\"${total_reg_cost:,.0f}\", f\"${total_ot_cost:,.0f}\", f\"${total_sc_cost:,.0f}\", \"$0\", f\"${total_monthly:,.0f}\"]\n",
        "    print(h_format.format(*totals))\n",
        "    print(\"-\" * 172)\n",
        "\n",
        "    grand_total = total_monthly + 9000\n",
        "\n",
        "    print(f\"\\n{'Regular Time Cost':<35} ${total_reg_cost:,.0f}\")\n",
        "    print(f\"{'Overtime Cost':<35} ${total_ot_cost:,.0f}\")\n",
        "    print(f\"{'Subcontracting Cost':<35} ${total_sc_cost:,.0f}\")\n",
        "    print(f\"{'Holding Cost':<35} $0\")\n",
        "    print(f\"{'Layoff Cost (3 workers x $3,000)':<35} $9,000\")\n",
        "    print(\"-\" * 45)\n",
        "    print(f\"{'GRAND TOTAL MIXED STRATEGY COST':<35} ${grand_total:,.0f}\")\n",
        "\n",
        "    return grand_total, {\"Reg. Cost\": reg_costs, \"OT Cost\": ot_costs, \"SC Cost\": sc_costs}\n",
        "\n",
        "def display_results(costs, level_plot, chase_plot, mixed_plot):\n",
        "    months = [\"January\", \"February\", \"March\", \"April\", \"May\", \"June\"]\n",
        "\n",
        "    print(\"\\n\" + \"=\"*80)\n",
        "    print(f\"{'STRATEGY COMPARISON & RECOMMENDATION':^80}\")\n",
        "    print(\"=\"*80 + \"\\n\")\n",
        "\n",
        "    print(\"-\" * 40)\n",
        "    print(f\"{'Strategy':<20} | {'Total Cost':<15}\")\n",
        "    print(\"-\" * 40)\n",
        "    for strategy, cost in costs.items():\n",
        "        print(f\"{strategy:<20} | ${cost:,.0f}\")\n",
        "    print(\"-\" * 40)\n",
        "\n",
        "    best_strategy = min(costs, key=costs.get)\n",
        "    lowest_cost = costs[best_strategy]\n",
        "\n",
        "    print(f\"\\n✅ RECOMMENDATION: The optimal choice is the {best_strategy.upper()} with the lowest total cost of ${lowest_cost:,.0f}.\\n\")\n",
        "\n",
        "    def create_stacked_chart(ax, title, data_dict, colors):\n",
        "        bottoms = np.zeros(6)\n",
        "        for (label, values), color in zip(data_dict.items(), colors):\n",
        "            ax.bar(months, values, label=label, bottom=bottoms, color=color, edgecolor='black', width=0.45)\n",
        "            bottoms += np.array(values)\n",
        "\n",
        "        ax.set_title(title, fontweight='bold', pad=15)\n",
        "        ax.set_ylabel('Cost ($)', fontweight='bold')\n",
        "        ax.legend(loc='center left', bbox_to_anchor=(1, 0.5), frameon=True)\n",
        "        ax.grid(axis='y', linestyle='-', alpha=0.3, color='gray')\n",
        "        ax.set_axisbelow(True)\n",
        "        ax.yaxis.set_major_formatter(plt.FuncFormatter(lambda x, loc: f\"${x:,.0f}\"))\n",
        "\n",
        "    fig, axes = plt.subplots(3, 1, figsize=(10, 16))\n",
        "\n",
        "    create_stacked_chart(axes[0], \"Level Strategy Monthly Costs\", level_plot, ['#7CB342', '#29B6F6', '#FFCA28'])\n",
        "    create_stacked_chart(axes[1], \"Chase Strategy Monthly Costs\", chase_plot, ['#7CB342', '#AB47BC', '#FF7043'])\n",
        "    create_stacked_chart(axes[2], \"Mixed Strategy Monthly Costs\", mixed_plot, ['#7CB342', '#7E57C2', '#EF5350'])\n",
        "\n",
        "    plt.tight_layout(pad=3.0)\n",
        "    plt.show()\n",
        "\n",
        "    strategies = list(costs.keys())\n",
        "    total_costs = list(costs.values())\n",
        "\n",
        "    plt.figure(figsize=(9, 5))\n",
        "    bars = plt.bar(strategies, total_costs, color=['#4CAF50', '#F44336', '#FF9800'], edgecolor='black')\n",
        "\n",
        "    for bar in bars:\n",
        "        yval = bar.get_height()\n",
        "        plt.text(bar.get_x() + bar.get_width()/2, yval + 800, f'${yval:,.0f}', ha='center', va='bottom', fontweight='bold', fontsize=11)\n",
        "\n",
        "    plt.title('Production Strategy Total Cost Comparison', fontsize=14, fontweight='bold', pad=15)\n",
        "    plt.ylabel('Total Cost ($)', fontsize=12)\n",
        "    plt.ylim(0, max(total_costs) + 10000)\n",
        "    plt.grid(axis='y', linestyle='--', alpha=0.7)\n",
        "    plt.gca().spines['top'].set_visible(False)\n",
        "    plt.gca().spines['right'].set_visible(False)\n",
        "    plt.show()\n",
        "\n",
        "# =====================================================================\n",
        "# MAIN EXECUTION\n",
        "# =====================================================================\n",
        "\n",
        "print(\"=\"*172)\n",
        "print(f\"{'1. LEVEL STRATEGY COMPUTATION':^172}\")\n",
        "print(\"=\"*172 + \"\\n\")\n",
        "cost_level, level_plot_data = calculate_level_strategy()\n",
        "\n",
        "print(\"\\n\\n\" + \"=\"*172)\n",
        "print(f\"{'2. CHASE STRATEGY COMPUTATION':^172}\")\n",
        "print(\"=\"*172 + \"\\n\")\n",
        "cost_chase, chase_plot_data = calculate_chase_strategy()\n",
