        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "def get_user_inputs():\n",
        "    print(\"=\"*70)\n",
        "    print(\"DYNAMIC PRODUCTION STRATEGY PARAMETER SETUP\")\n",
        "    print(\"=\"*70)\n",
        "\n",
        "    all_months = [\"January\", \"February\", \"March\", \"April\", \"May\", \"June\",\n",
        "                  \"July\", \"August\", \"September\", \"October\", \"November\", \"December\"]\n",
        "    months = []\n",
        "    demands = []\n",
        "\n",
        "    print(\"\\n--- Enter Monthly Demand ---\")\n",
        "    print(\"Instruction: Type a number for demand. If you want to skip a month, just press ENTER without typing anything.\")\n",
        "\n",
        "    for month in all_months:\n",
        "        while True:\n",
        "            user_input = input(f\"Demand for {month} (leave blank to skip): \").strip()\n",
        "\n",
        "            if user_input == \"\":\n",
        "                break\n",
        "\n",
        "            try:\n",
        "                d = int(user_input)\n",
        "                months.append(month)\n",
        "                demands.append(d)\n",
        "                break\n",
        "            except ValueError:\n",
        "                print(\"Please enter a valid integer, or press Enter to skip.\")\n",
        "\n",
        "    if len(months) == 0:\n",
        "        print(\"\\nError: You skipped all months. Please restart the cell and enter at least one month of demand.\")\n",
        "        return None, None, None, None, None\n",
        "\n",
        "    print(\"\\n--- Enter Strategy Parameters ---\")\n",
        "    while True:\n",
        "        try:\n",
        "            initial_workers = int(input(\"1. Initial starting workforce for CHASE strategy (e.g., 8): \"))\n",
        "            level_fixed_prod = int(input(\"2. Fixed Production Size for LEVEL strategy (e.g., 1600): \"))\n",
        "            mixed_base_workers = int(input(\"3. Base number of workers for MIXED strategy (e.g., 5): \"))\n",
        "            break\n",
        "        except ValueError:\n",
        "            print(\"Please enter valid integers.\")\n",
        "\n",
        "    return months, demands, initial_workers, level_fixed_prod, mixed_base_workers\n",
        "\n",
        "def calculate_level_strategy(months, demands, fixed_prod):\n",
        "    print(\"\\n\\n\" + \"=\"*135)\n",
        "    print(f\"{'1. LEVEL STRATEGY COMPUTATION':^135}\")\n",
        "    print(\"=\"*135)\n",
        "\n",
        "    HOLDING_COST_RATE = 5\n",
        "    BACKORDER_COST_RATE = 8\n",
        "    REGULAR_COST = fixed_prod * 3\n",
        "\n",
        "    beg_inventory = 0\n",
        "    total_demand = total_production = total_beg_inv = total_end_inv = total_backorders = total_units_held = total_holding_cost = total_backorder_cost = total_regular_cost = 0\n",
        "\n",
        "    reg_costs, hold_costs, back_costs = [], [], []\n",
        "\n",
        "    headers = [\"Month\", \"Demand\", \"Production\", \"Beg. Inventory\", \"End Inventory\", \"Backorders\", \"Units Held\", \"Holding Cost\", \"Backorder Cost\", \"Regular Cost\"]\n",
        "    header_format = \"{:<12} | {:>8} | {:>10} | {:>14} | {:>13} | {:>10} | {:>10} | {:>12} | {:>14} | {:>12}\"\n",
        "    print(\"-\" * 135)\n",
        "    print(header_format.format(*headers))\n",
        "    print(\"-\" * 135)\n",
        "\n",
        "    for i in range(len(months)):\n",
        "        month = months[i]\n",
        "        demand = demands[i]\n",
        "\n",
        "        net_inventory = beg_inventory + fixed_prod - demand\n",
        "\n",
        "        if net_inventory >= 0:\n",
        "            ending_inventory = net_inventory\n",
        "            backorders = 0\n",
        "        else:\n",
        "            ending_inventory = 0\n",
        "            backorders = abs(net_inventory)\n",
        "\n",
        "        units_held = ending_inventory\n",
        "        holding_cost = units_held * HOLDING_COST_RATE\n",
        "        backorder_cost = backorders * BACKORDER_COST_RATE\n",
        "\n",
        "        reg_costs.append(REGULAR_COST)\n",
        "        hold_costs.append(holding_cost)\n",
        "        back_costs.append(backorder_cost)\n",
        "\n",
        "        row_data = [month, demand, fixed_prod, beg_inventory, ending_inventory, backorders, units_held, f\"${holding_cost:,.0f}\", f\"${backorder_cost:,.0f}\", f\"${REGULAR_COST:,.0f}\"]\n",
        "        print(header_format.format(*row_data))\n",
        "\n",
        "        total_demand += demand\n",
        "        total_production += fixed_prod\n",
        "        total_beg_inv += beg_inventory\n",
        "        total_end_inv += ending_inventory\n",
        "        total_backorders += backorders\n",
        "        total_units_held += units_held\n",
        "        total_holding_cost += holding_cost\n",
        "        total_backorder_cost += backorder_cost\n",
        "        total_regular_cost += REGULAR_COST\n",
        "        beg_inventory = ending_inventory\n",
        "\n",
        "    print(\"-\" * 135)\n",
        "    totals_row = [\"TOTAL\", total_demand, total_production, total_beg_inv, total_end_inv, total_backorders, total_units_held, f\"${total_holding_cost:,.0f}\", f\"${total_backorder_cost:,.0f}\", f\"${total_regular_cost:,.0f}\"]\n",
        "    print(header_format.format(*totals_row))\n",
        "    print(\"-\" * 135)\n",
        "\n",
        "    total_strategy_cost = total_holding_cost + total_backorder_cost + total_regular_cost\n",
        "    print(f\"\\n{'TOTAL LEVEL STRATEGY COST':<25} ${total_strategy_cost:,.0f}\")\n",
        "    return total_strategy_cost, {\"Regular Cost\": reg_costs, \"Holding Cost\": hold_costs, \"Backorder Cost\": back_costs}\n",
        "\n",
        "def calculate_chase_strategy(months, demands, initial_workers):\n",
        "    print(\"\\n\\n\" + \"=\"*135)\n",
        "    print(f\"{'2. CHASE STRATEGY COMPUTATION':^135}\")\n",
        "    print(\"=\"*135)\n",
        "\n",
        "    UNITS_PER_WORKER = 200\n",
        "    HIRING_COST_RATE = 2400\n",
        "    LAYOFF_COST_RATE = 3000\n",
        "    REGULAR_COST_RATE = 600\n",
        "\n",
        "    workers_available = initial_workers\n",
        "    total_demand = total_workers_needed = total_hired = total_laid_off = total_production = total_hiring_cost = total_layoff_cost = total_regular_cost = 0\n",
        "\n",
        "    reg_costs, hire_costs, layoff_costs = [], [], []\n",
        "\n",
        "    headers = [\"Month\", \"Demand\", \"Workers Needed\", \"Workers Avail\", \"Workers Hired\", \"Workers Fired\", \"Production\", \"Hiring Cost\", \"Layoff Cost\", \"Regular Cost\"]\n",
        "    header_format = \"{:<12} | {:>8} | {:>14} | {:>13} | {:>13} | {:>13} | {:>10} | {:>11} | {:>11} | {:>12}\"\n",
        "    print(\"-\" * 135)\n",
        "    print(header_format.format(*headers))\n",
        "    print(\"-\" * 135)\n",
        "\n",
        "    for i in range(len(months)):\n",
        "        month = months[i]\n",
        "        demand = demands[i]\n",
        "\n",
        "        workers_needed = int(np.ceil(demand / UNITS_PER_WORKER))\n",
        "        production = workers_needed * UNITS_PER_WORKER\n",
        "\n",
        "        if workers_needed > workers_available:\n",
        "            workers_hired = workers_needed - workers_available\n",
        "            workers_laid_off = 0\n",
        "        elif workers_needed < workers_available:\n",
        "            workers_hired = 0\n",
        "            workers_laid_off = workers_available - workers_needed\n",
        "        else:\n",
        "            workers_hired = 0\n",
        "            workers_laid_off = 0\n",
        "\n",
        "        hiring_cost = workers_hired * HIRING_COST_RATE\n",
        "        layoff_cost = workers_laid_off * LAYOFF_COST_RATE\n",
        "        regular_cost = workers_needed * REGULAR_COST_RATE\n",
        "\n",
        "        reg_costs.append(regular_cost)\n",
        "        hire_costs.append(hiring_cost)\n",
        "        layoff_costs.append(layoff_cost)\n",
        "\n",
        "        row_data = [month, demand, workers_needed, workers_available, workers_hired, workers_laid_off, production, f\"${hiring_cost:,.0f}\", f\"${layoff_cost:,.0f}\", f\"${regular_cost:,.0f}\"]\n",
        "        print(header_format.format(*row_data))\n",
        "\n",
        "        total_demand += demand\n",
        "        total_workers_needed += workers_needed\n",
        "        total_hired += workers_hired\n",
        "        total_laid_off += workers_laid_off\n",
        "        total_production += production\n",
        "        total_hiring_cost += hiring_cost\n",
        "        total_layoff_cost += layoff_cost\n",
        "        total_regular_cost += regular_cost\n",
        "        workers_available = workers_needed\n",
        "\n",
        "    print(\"-\" * 135)\n",
        "    totals_row = [\"TOTAL\", total_demand, total_workers_needed, \"-\", total_hired, total_laid_off, total_production, f\"${total_hiring_cost:,.0f}\", f\"${total_layoff_cost:,.0f}\", f\"${total_regular_cost:,.0f}\"]\n",
        "    print(header_format.format(*totals_row))\n",
        "    print(\"-\" * 135)\n",
        "\n",
        "    total_strategy_cost = total_hiring_cost + total_layoff_cost + total_regular_cost\n",
        "    print(f\"\\n{'TOTAL CHASE STRATEGY COST':<25} ${total_strategy_cost:,.0f}\")\n",
        "    return total_strategy_cost, {\"Regular Cost\": reg_costs, \"Hiring Cost\": hire_costs, \"Layoff Cost\": layoff_costs}\n",
        "\n",
        "def calculate_mixed_strategy(months, demands, initial_workers, base_workers):\n",
        "    print(\"\\n\\n\" + \"=\"*135)\n",
        "    print(f\"{'3. MIXED STRATEGY COMPUTATION':^135}\")\n",
        "    print(\"=\"*135)\n",
        "\n",
        "    REG_PROD = base_workers * 200\n",
        "    MAX_OT = base_workers * 50\n",
        "\n",
        "    REG_COST_RATE = 4.5\n",
        "    OT_COST_RATE = 6.0\n",
        "    SC_COST_RATE = 5.0\n",
        "    LAYOFF_RATE = 3000\n",
        "\n",
        "    workers_laid_off = max(0, initial_workers - base_workers)\n",
        "    initial_layoff_cost = workers_laid_off * LAYOFF_RATE\n",
        "\n",
        "    if initial_layoff_cost > 0:\n",
        "        print(f\"\\nONE-TIME LAYOFF COST: Reduced from {initial_workers} to {base_workers} workers = {workers_laid_off} laid off x $3,000 = ${initial_layoff_cost:,.0f}\\n\")\n",
        "    else:\n",
        "        print(f\"\\nNO INITIAL LAYOFF REQUIRED. Starting with {base_workers} workers.\\n\")\n",
        "\n",
        "    total_demand = total_reg_prod = total_max_ot = total_ot_used = total_sc = total_supply = total_reg_cost = total_ot_cost = total_sc_cost = total_monthly = 0\n",
        "\n",
        "    reg_costs, ot_costs, sc_costs = [], [], []\n",
        "\n",
        "    headers = [\"Month\", \"Demand\", \"Reg. Prod\", \"Max OT\", \"OT Used\", \"Subcontracted\", \"Total Supply\", \"Reg. Cost\", \"OT Cost\", \"SC Cost\", \"Monthly Total\"]\n",
        "    h_format = \"{:<12} | {:>8} | {:>9} | {:>8} | {:>9} | {:>13} | {:>12} | {:>10} | {:>9} | {:>9} | {:>13}\"\n",
        "    print(\"-\" * 135)\n",
        "    print(h_format.format(*headers))\n",
        "    print(\"-\" * 135)\n",
        "\n",
        "    for i in range(len(months)):\n",
        "        month = months[i]\n",
        "        demand = demands[i]\n",
        "\n",
        "        shortfall = max(0, demand - REG_PROD)\n",
        "        ot_used = min(shortfall, MAX_OT)\n",
        "        subcontracted = max(0, shortfall - ot_used)\n",
        "\n",
        "        total_sup = REG_PROD + ot_used + subcontracted\n",
        "\n",
        "        reg_cost = REG_PROD * REG_COST_RATE\n",
        "        ot_cost = ot_used * OT_COST_RATE\n",
        "        sc_cost = subcontracted * SC_COST_RATE\n",
        "        monthly_total = reg_cost + ot_cost + sc_cost\n",
        "\n",
        "        reg_costs.append(reg_cost)\n",
        "        ot_costs.append(ot_cost)\n",
        "        sc_costs.append(sc_cost)\n",
        "\n",
        "        row = [month, demand, REG_PROD, MAX_OT, ot_used, subcontracted, total_sup, f\"${reg_cost:,.0f}\", f\"${ot_cost:,.0f}\", f\"${sc_cost:,.0f}\", f\"${monthly_total:,.0f}\"]\n",
        "        print(h_format.format(*row))\n",
        "\n",
        "        total_demand += demand\n",
        "        total_reg_prod += REG_PROD\n",
        "        total_max_ot += MAX_OT\n",
        "        total_ot_used += ot_used\n",
        "        total_sc += subcontracted\n",
        "        total_supply += total_sup\n",
        "        total_reg_cost += reg_cost\n",
        "        total_ot_cost += ot_cost\n",
        "        total_sc_cost += sc_cost\n",
        "        total_monthly += monthly_total\n",
        "\n",
        "    print(\"-\" * 135)\n",
        "    totals = [\"TOTAL\", total_demand, total_reg_prod, total_max_ot, total_ot_used, total_sc, total_supply, f\"${total_reg_cost:,.0f}\", f\"${total_ot_cost:,.0f}\", f\"${total_sc_cost:,.0f}\", f\"${total_monthly:,.0f}\"]\n",
        "    print(h_format.format(*totals))\n",
        "    print(\"-\" * 135)\n",
        "\n",
        "    grand_total = total_monthly + initial_layoff_cost\n",
        "    print(f\"\\n{'GRAND TOTAL MIXED STRATEGY COST':<35} ${grand_total:,.0f} (Includes ${initial_layoff_cost:,.0f} initial setup cost)\")\n",
        "    return grand_total, {\"Reg. Cost\": reg_costs, \"OT Cost\": ot_costs, \"SC Cost\": sc_costs}\n",
        "\n",
        "def display_results(months, costs, level_plot, chase_plot, mixed_plot):\n",
        "    print(\"\\n\" + \"=\"*80)\n",
        "    print(f\"{'STRATEGY COMPARISON & RECOMMENDATION':^80}\")\n",
        "    print(\"=\"*80 + \"\\n\")\n",
        "\n",
        "    print(\"-\" * 40)\n",
        "    print(f\"{'Strategy':<20} | {'Total Cost':<15}\")\n",
        "    print(\"-\" * 40)\n",
        "    for strategy, cost in costs.items():\n",
        "        print(f\"{strategy:<20} | ${cost:,.0f}\")\n",
        "    print(\"-\" * 40)\n",
        "\n",
        "    best_strategy = min(costs, key=costs.get)\n",
        "    lowest_cost = costs[best_strategy]\n",
        "    print(f\"\\nRECOMMENDATION: The optimal choice is the {best_strategy.upper()} with the lowest total cost of ${lowest_cost:,.0f}.\\n\")\n",
        "\n",
        "    def create_stacked_chart(ax, title, data_dict, colors):\n",
        "        bottoms = np.zeros(len(months))\n",
        "        short_months = [m[:3] for m in months]\n",
        "\n",
        "        for (label, values), color in zip(data_dict.items(), colors):\n",
        "            ax.bar(short_months, values, label=label, bottom=bottoms, color=color, edgecolor='black', width=0.5)\n",
        "            bottoms += np.array(values)\n",
        "\n",
        "        ax.set_title(title, fontweight='bold', pad=15)\n",
        "        ax.set_ylabel('Cost ($)', fontweight='bold')\n",
        "        ax.legend(loc='center left', bbox_to_anchor=(1, 0.5), frameon=True)\n",
        "        ax.grid(axis='y', linestyle='-', alpha=0.3, color='gray')\n",
        "        ax.set_axisbelow(True)\n",
        "        ax.yaxis.set_major_formatter(plt.FuncFormatter(lambda x, loc: f\"${x:,.0f}\"))\n",
        "\n",
        "    fig, axes = plt.subplots(3, 1, figsize=(12, 18))\n",
        "    create_stacked_chart(axes[0], \"Level Strategy Monthly Costs\", level_plot, ['#7CB342', '#29B6F6', '#FFCA28'])\n",
        "    create_stacked_chart(axes[1], \"Chase Strategy Monthly Costs\", chase_plot, ['#7CB342', '#AB47BC', '#FF7043'])\n",
        "    create_stacked_chart(axes[2], \"Mixed Strategy Monthly Costs\", mixed_plot, ['#7CB342', '#7E57C2', '#EF5350'])\n",
        "    plt.tight_layout(pad=4.0)\n",
        "    plt.show()\n",
        "\n",
        "    strategies = list(costs.keys())\n",
        "    total_costs = list(costs.values())\n",
        "    plt.figure(figsize=(9, 5))\n",
        "    bars = plt.bar(strategies, total_costs, color=['#4CAF50', '#F44336', '#FF9800'], edgecolor='black', width=0.6)\n",
        "\n",
        "    for bar in bars:\n",
        "        yval = bar.get_height()\n",
        "        plt.text(bar.get_x() + bar.get_width()/2, yval + (max(total_costs)*0.02), f'${yval:,.0f}', ha='center', va='bottom', fontweight='bold', fontsize=11)\n",
        "\n",
        "    plt.title(f'Production Strategy Total Cost Comparison ({len(months)} Active Months)', fontsize=14, fontweight='bold', pad=15)\n",
        "    plt.ylabel('Total Cost ($)', fontsize=12)\n",
        "    plt.ylim(0, max(total_costs) * 1.15)\n",
        "    plt.grid(axis='y', linestyle='--', alpha=0.7)\n",
        "    plt.gca().spines['top'].set_visible(False)\n",
        "    plt.gca().spines['right'].set_visible(False)\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "months, demands, initial_workers, level_fixed_prod, mixed_base_workers = get_user_inputs()\n",
        "\n",
        "if months:\n",
        "    cost_level, level_plot_data = calculate_level_strategy(months, demands, level_fixed_prod)\n",
        "    cost_chase, chase_plot_data = calculate_chase_strategy(months, demands, initial_workers)\n",
        "    cost_mixed, mixed_plot_data = calculate_mixed_strategy(months, demands, initial_workers, mixed_base_workers)\n",
        "\n",
        "    strategy_costs = {\n",
        "        \"Level Strategy\": cost_level,\n",
        "        \"Chase Strategy\": cost_chase,\n",
        "        \"Mixed Strategy\": cost_mixed\n",
        "    }\n",
        "\n",
        "    display_results(months, strategy_costs, level_plot_data, chase_plot_data, mixed_plot_data)"
      ],
